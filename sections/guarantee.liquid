<section class="guarantee">
  <div class="container">
    <div class="guarantee-inner">
      <div class="guarantee-badge">
        <div class="badge-circle">
          <span class="badge-num">{{ section.settings.days }}</span>
          <span class="badge-label">{{ section.settings.badge_label }}</span>
        </div>
      </div>
      <div class="guarantee-text">
        {%- if section.settings.eyebrow != blank -%}
          <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        <h2 class="section-title">{{ section.settings.heading }}</h2>
        <div>{{ section.settings.body }}</div>
        {%- if section.settings.button_text != blank -%}
          <a href="{{ section.settings.button_link }}" class="btn-primary btn-dark">
            {{ section.settings.button_text }} <span class="arrow">→</span>
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Guarantee",
  "settings": [
    { "type": "text", "id": "days", "label": "Days number", "default": "30" },
    { "type": "html", "id": "badge_label", "label": "Badge label", "default": "nights<br>risk-free" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our promise" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Sleep on it for 30 nights." },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>We're so sure Dreamtape will change your sleep, we offer a 30-night money-back guarantee. If you're not waking up better-rested, send us one email — we'll refund you in full. No questions, no fuss.</p>" },
    { "type": "text", "id": "button_text", "label": "Button text", "default": "Try Dreamtape now" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [{ "name": "Guarantee" }]
}
{% endschema %}
