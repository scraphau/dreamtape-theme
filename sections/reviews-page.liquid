<section class="reviews-page" style="{% render 'section-color-vars', section: section %}" data-reviews-page>
  <div class="container">
    <div class="reviews-hero">
      <h1>{{ section.settings.heading }}</h1>
      <p class="reviews-kicker">{{ section.settings.kicker }}</p>
    </div>

    <div class="reviews-summary">
      <div class="reviews-score">
        <div class="reviews-stars" aria-label="4.7 out of 5 stars">&#9733;&#9733;&#9733;&#9733;&#9734;</div>
        <a href="#reviews-list">4.7 out of 5</a>
        <p>Based on <span data-review-count>874</span> reviews</p>
      </div>

      <div class="reviews-breakdown" aria-label="Rating breakdown">
        <div class="reviews-bar-row">
          <span>&#9733;&#9733;&#9733;&#9733;&#9733;</span>
          <div class="reviews-bar"><span style="width: 82%;"></span></div>
          <small>721</small>
        </div>
        <div class="reviews-bar-row">
          <span>&#9733;&#9733;&#9733;&#9733;&#9734;</span>
          <div class="reviews-bar"><span style="width: 16%;"></span></div>
          <small>112</small>
        </div>
        <div class="reviews-bar-row">
          <span>&#9733;&#9733;&#9733;&#9734;&#9734;</span>
          <div class="reviews-bar"><span style="width: 4%;"></span></div>
          <small>22</small>
        </div>
        <div class="reviews-bar-row">
          <span>&#9733;&#9733;&#9734;&#9734;&#9734;</span>
          <div class="reviews-bar"><span style="width: 2%;"></span></div>
          <small>9</small>
        </div>
        <div class="reviews-bar-row">
          <span>&#9733;&#9734;&#9734;&#9734;&#9734;</span>
          <div class="reviews-bar"><span style="width: 2%;"></span></div>
          <small>10</small>
        </div>
      </div>

      <button class="reviews-write-btn" type="button" data-review-open>Write a Store Review</button>
    </div>

    <div class="reviews-toolbar">
      <div class="reviews-tabs">
        <a href="#reviews-list">Product Reviews (<span data-review-count>874</span>)</a>
        <a href="#reviews-list">Shop Reviews (29)</a>
      </div>
      <label>
        <span class="visually-hidden">Sort reviews</span>
        <select data-review-sort>
          <option value="recent">Most Recent</option>
          <option value="highest">Highest Rating</option>
          <option value="lowest">Lowest Rating</option>
        </select>
      </label>
    </div>

    <div class="reviews-grid" id="reviews-list" data-reviews-list>
      <article class="review-card" data-seed-review data-rating="5">
        <div class="review-card-top">
          <span>about <a href="/collections/all">Dreamtape Mouth Tape</a></span>
          <time>3 days ago</time>
        </div>
        <div class="reviews-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
        <div class="review-author">
          <span class="review-avatar" aria-hidden="true"></span>
          <span>S Paul</span>
          <strong>Verified</strong>
        </div>
        <h3>Incredible!</h3>
        <p>I had no idea how badly my sleep was being affected until I tried these. I wake up feeling clearer and more rested.</p>
      </article>

      <article class="review-card" data-seed-review data-rating="5">
        <div class="review-card-top">
          <span>about <a href="/collections/all">Dreamtape Mouth Tape</a></span>
          <time>3 days ago</time>
        </div>
        <div class="reviews-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
        <div class="review-author">
          <span class="review-avatar" aria-hidden="true"></span>
          <span>Deanne C</span>
          <strong>Verified</strong>
        </div>
        <h3>Sleep better</h3>
        <p>I sleep much better when I wear these. They stay on the whole night and make breathing easier.</p>
      </article>

      <article class="review-card" data-seed-review data-rating="4">
        <div class="review-card-top">
          <span>about <a href="/collections/all">Dreamtape Mouth Tape</a></span>
          <time>6 days ago</time>
        </div>
        <div class="reviews-stars">&#9733;&#9733;&#9733;&#9733;&#9734;</div>
        <div class="review-author">
          <span class="review-avatar" aria-hidden="true"></span>
          <span>Josh W</span>
          <strong>Verified</strong>
        </div>
        <h3>Really did help!</h3>
        <p>These make it easier to breathe and sleep comfortably at night. Gave them a go and noticed the difference.</p>
      </article>
    </div>
  </div>

  <dialog class="review-dialog" data-review-dialog>
    <form class="review-form" method="dialog" data-review-form>
      <button class="review-dialog-close" type="button" aria-label="Close review form" data-review-close>&times;</button>
      <h2>Write a review</h2>

      <fieldset class="review-rating-field">
        <legend>Rating</legend>
        <div class="review-rating-input" data-review-rating>
          {%- for rating in (1..5) -%}
            <button type="button" aria-label="{{ rating }} star rating" data-rating-value="{{ rating }}">&#9734;</button>
          {%- endfor -%}
        </div>
        <input type="hidden" name="rating" value="5" data-review-rating-value>
      </fieldset>

      <label>
        <span>Review Title <small>(100)</small></span>
        <input type="text" name="title" maxlength="100" placeholder="Give your review a title" required>
      </label>

      <label>
        <span>Review content</span>
        <textarea name="content" rows="5" placeholder="Start writing here..." required></textarea>
      </label>

      <label class="review-upload">
        <span>Picture/Video (optional)</span>
        <input type="file" name="media" accept="image/*,video/*">
        <span class="review-upload-box" aria-hidden="true">
          <svg width="42" height="42" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <path d="M12 3v12"></path>
            <path d="M7 8l5-5 5 5"></path>
            <path d="M5 14v5h14v-5"></path>
          </svg>
        </span>
      </label>

      <label>
        <span>Display name</span>
        <input type="text" name="name" placeholder="Display name" required>
      </label>

      <label>
        <span>Email address</span>
        <input type="email" name="email" placeholder="Your email address" required>
      </label>

      <p class="review-privacy">We will only contact you about the review you left, and only if necessary.</p>

      <div class="review-form-actions">
        <button class="btn-secondary" type="button" data-review-close>Cancel review</button>
        <button class="btn-primary btn-dark" type="submit">Submit Review</button>
      </div>
    </form>
  </dialog>
</section>

{% schema %}
{
  "name": "Reviews page",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#0e1a3a"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Muted text color",
      "default": "#5a6580"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#0e9aa0"
    },
    {
      "type": "color",
      "id": "card_background_color",
      "label": "Card background color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Dreamtape Reviews"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "1M+ STRIPS SOLD - 100K+ RESTED CUSTOMERS"
    }
  ]
}
{% endschema %}
