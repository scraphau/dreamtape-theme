<footer class="footer" style="{% render 'section-color-vars', section: section %}">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <a href="{{ routes.root_url }}" class="logo logo-footer" aria-label="{{ shop.name }} home">
          <img
            src="{{ 'dreamtape-logo.png' | asset_url }}"
            alt="{{ shop.name }}"
            class="logo-image"
            width="1006"
            height="233"
          >
        </a>
        {%- if section.settings.tagline != blank -%}
          <p>{{ section.settings.tagline }}</p>
        {%- endif -%}
        <div class="social">
          {%- if section.settings.instagram != blank -%}
            <a href="{{ section.settings.instagram }}" aria-label="Instagram" target="_blank" rel="noopener"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg></a>
          {%- endif -%}
          {%- if section.settings.tiktok != blank -%}
            <a href="{{ section.settings.tiktok }}" aria-label="TikTok" target="_blank" rel="noopener"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 12a4 4 0 104 4V4a5 5 0 005 5"/></svg></a>
          {%- endif -%}
          {%- if section.settings.facebook != blank -%}
            <a href="{{ section.settings.facebook }}" aria-label="Facebook" target="_blank" rel="noopener"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg></a>
          {%- endif -%}
        </div>
      </div>

      {%- for block in section.blocks -%}
        {%- if block.type == 'menu' -%}
          <div class="footer-col">
            <h4>{{ block.settings.heading }}</h4>
            {%- if block.settings.menu != blank -%}
              {%- for link in block.settings.menu.links -%}
                <a href="{{ link.url }}">{{ link.title }}</a>
              {%- endfor -%}
            {%- endif -%}
          </div>
        {%- elsif block.type == 'newsletter' -%}
          <div class="footer-col">
            <h4>{{ block.settings.heading }}</h4>
            {%- if block.settings.subheading != blank -%}
              <p>{{ block.settings.subheading }}</p>
            {%- endif -%}
            {%- form 'customer', class: 'signup' -%}
              <input type="hidden" name="contact[tags]" value="newsletter">
              <input type="email" name="contact[email]" placeholder="your@email.com" required>
              <button type="submit">Join</button>
            {%- endform -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="footer-bottom">
      <p>© {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
      <div class="footer-links">
        <a href="/policies/privacy-policy">Privacy</a>
        <a href="/policies/terms-of-service">Terms</a>
        <a href="/policies/refund-policy">Refund Policy</a>
      </div>
    </div>

    {%- if section.settings.disclaimer != blank -%}
      <p class="disclaimer">{{ section.settings.disclaimer }}</p>
    {%- endif -%}
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#07102a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Muted text color",
      "default": "#dbe5f6"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_background_color",
      "label": "Card background color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Brand tagline",
      "default": "Sleep like you're meant to."
    },
    {
      "type": "url",
      "id": "instagram",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "tiktok",
      "label": "TikTok URL"
    },
    {
      "type": "url",
      "id": "facebook",
      "label": "Facebook URL"
    },
    {
      "type": "textarea",
      "id": "disclaimer",
      "label": "Disclaimer",
      "default": "*This product is not intended to diagnose, treat, cure, or prevent any disease."
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Shop"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Newsletter"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading",
          "default": "Get 15% off your first order."
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "menu",
        "settings": {
          "heading": "Shop"
        }
      },
      {
        "type": "menu",
        "settings": {
          "heading": "Help"
        }
      },
      {
        "type": "newsletter"
      }
    ]
  }
}
{% endschema %}
