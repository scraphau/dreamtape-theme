<section class="products" id="shop" style="{% render 'section-color-vars', section: section %}">
  <div class="container">
    <div class="section-head">
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 class="section-title">{{ section.settings.heading }}</h2>
    </div>
    <div class="product-grid product-grid--centered">
      {%- if section.settings.product != blank -%}
        {%- assign featured = all_products[section.settings.product] -%}
        {%- render 'product-card', product: featured, image: section.settings.card_image -%}
      {%- elsif section.settings.collection != blank -%}
        {%- assign col = collections[section.settings.collection] -%}
        {%- for product in col.products limit: 1 -%}
          {%- render 'product-card', product: product, image: section.settings.card_image -%}
        {%- endfor -%}
      {%- else -%}
        <article class="product-card">
          <div class="product-image">
            <div class="product-image-placeholder">◐</div>
          </div>
          <div class="product-body">
            <h3>Mouth Tape</h3>
            <p>Pick a product in the theme editor to display it here.</p>
            <a href="/products/mouth-tape" class="btn-primary btn-dark btn-full">LEARN MORE</a>
          </div>
        </article>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured products",
  "settings": [
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#f3f6fb" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#0e1a3a" },
    { "type": "color", "id": "muted_text_color", "label": "Muted text color", "default": "#5a6580" },
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#0e1a3a" },
    { "type": "color", "id": "card_background_color", "label": "Card background color", "default": "#ffffff" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our collection" },
    { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p>Everything for your <em>nasal breathing</em> ritual.</p>" },
    { "type": "product", "id": "product", "label": "Product (shows single centred card)" },
    { "type": "collection", "id": "collection", "label": "Collection (fallback, shows first product)" },
    { "type": "image_picker", "id": "card_image", "label": "Card image override", "info": "Optional. Overrides the product's own photo on this card only — the product page and other channels are unaffected." }
  ],
  "presets": [{ "name": "Featured products" }]
}
{% endschema %}
