<section class="products" id="shop" style="{% render 'section-color-vars', section: section %}">
  <div class="container">
    <div class="section-head">
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 class="section-title">{{ section.settings.heading }}</h2>
    </div>
    <div class="product-grid">
      {%- assign collection = collections[section.settings.collection] -%}
      {%- if collection != blank and collection.products.size > 0 -%}
        {%- for product in collection.products limit: section.settings.products_to_show -%}
          {%- render 'product-card', product: product -%}
        {%- endfor -%}
      {%- else -%}
        {%- comment -%} Fallback placeholder cards if no collection set {%- endcomment -%}
        {%- for i in (1..3) -%}
          <article class="product-card">
            <div class="product-image">
              <div class="product-image-placeholder">◐</div>
            </div>
            <div class="product-body">
              <h3>Product title</h3>
              <p>Connect a collection to display real products here.</p>
              <div class="product-meta">
                <span class="price">$32</span>
              </div>
              <a href="#" class="btn-primary btn-dark btn-full">View product</a>
            </div>
          </article>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured products",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f3f6fb"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#0e1a3a"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Muted text color",
      "default": "#5a6580"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#0e1a3a"
    },
    {
      "type": "color",
      "id": "card_background_color",
      "label": "Card background color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Our collection"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Everything for your <em>nasal breathing</em> ritual.</p>"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 3
    }
  ],
  "presets": [
    {
      "name": "Featured products"
    }
  ]
}
{% endschema %}
