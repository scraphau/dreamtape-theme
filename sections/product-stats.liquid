<section class="product-stats-section" style="{% render 'section-color-vars', section: section %}">
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <div class="section-head section-head-center reveal">
        <h2 class="section-title">{{ section.settings.heading | replace: '[em]', '<em>' | replace: '[/em]', '</em>' }}</h2>
      </div>
    {%- endif -%}
    <div class="product-stats-grid">
      {%- for i in (1..3) -%}
        {%- assign num_key = 'stat_' | append: i | append: '_number' -%}
        {%- assign label_key = 'stat_' | append: i | append: '_label' -%}
        {%- assign num = section.settings[num_key] -%}
        {%- assign label = section.settings[label_key] -%}
        {%- if num != blank -%}
          <div class="product-stat reveal">
            <div class="product-stat-number">{{ num }}</div>
            <p>{{ label }}</p>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Stats row",
  "settings": [
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#0e1a3a" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#ffffff" },
    { "type": "color", "id": "muted_text_color", "label": "Muted text color", "default": "rgba(255,255,255,0.7)" },
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#ffffff" },
    { "type": "color", "id": "card_background_color", "label": "Card background color", "default": "#1b2d5a" },
    { "type": "text", "id": "heading", "label": "Heading (optional, use [em]...[/em])", "default": "" },
    { "type": "text", "id": "stat_1_number", "label": "Stat 1 — number", "default": "82%" },
    { "type": "text", "id": "stat_1_label", "label": "Stat 1 — label", "default": "of members had fewer sleep disruptions" },
    { "type": "text", "id": "stat_2_number", "label": "Stat 2 — number", "default": "76%" },
    { "type": "text", "id": "stat_2_label", "label": "Stat 2 — label", "default": "felt more energised every morning" },
    { "type": "text", "id": "stat_3_number", "label": "Stat 3 — number", "default": "87%" },
    { "type": "text", "id": "stat_3_label", "label": "Stat 3 — label", "default": "report improved quality of life within 3 months" }
  ]
}
{% endschema %}
