<section class="benefits" style="{% render 'section-color-vars', section: section %}">
  <div class="container">
    <div class="section-head section-head-center">
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 class="section-title">{{ section.settings.heading }}</h2>
      {%- if section.settings.lead != blank -%}
        <p class="section-lead">{{ section.settings.lead }}</p>
      {%- endif -%}
    </div>
    <div class="benefits-grid">
      {%- for block in section.blocks -%}
        <div class="benefit">
          <svg class="benefit-cloud" viewBox="0 0 240 160" preserveAspectRatio="none" aria-hidden="true" focusable="false">
            <g class="benefit-cloud-fill">
              <rect x="20" y="72" width="200" height="66" rx="33"/>
              <circle cx="58" cy="72" r="34"/>
              <circle cx="108" cy="52" r="42"/>
              <circle cx="162" cy="58" r="38"/>
              <circle cx="206" cy="76" r="30"/>
            </g>
          </svg>
          <div class="benefit-content">
            <div class="benefit-icon">{% render 'icon-line', icon: block.settings.icon %}</div>
            <h4>{{ block.settings.title }}</h4>
            <p>{{ block.settings.body }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Benefits",
  "max_blocks": 9,
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#0e1a3a"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Muted text color",
      "default": "#5a6580"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#0e1a3a"
    },
    {
      "type": "color",
      "id": "card_background_color",
      "label": "Card background color",
      "default": "#f3f6fb"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "One fix. Many wins."
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>A cascade of benefits<br>from <em>one small strip</em>.</p>"
    },
    {
      "type": "textarea",
      "id": "lead",
      "label": "Lead text",
      "default": "When you switch from mouth to nose breathing, you unlock better oxygenation, deeper REM, a stronger jawline, and a sharper immune system — naturally and effortlessly."
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "snore", "label": "Moon (sleep)" },
            { "value": "energy", "label": "Lightning (energy)" },
            { "value": "breath", "label": "Tooth (fresh breath)" },
            { "value": "posture", "label": "Muscle (posture)" },
            { "value": "shield", "label": "Shield (protection)" },
            { "value": "calm", "label": "Brain (calm)" }
          ],
          "default": "snore"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Stop snoring"
        },
        {
          "type": "text",
          "id": "body",
          "label": "Body",
          "default": "Quiet nights for you and anyone next to you."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Benefits",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "icon": "snore",
            "title": "Stop snoring",
            "body": "Quiet nights for you (and anyone next to you)."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "posture",
            "title": "Sharper jawline",
            "body": "Proper tongue posture supports facial structure."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "energy",
            "title": "More energy",
            "body": "Deeper REM means brighter mornings."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "shield",
            "title": "Boost immunity",
            "body": "Nasal breathing filters and humidifies air."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "calm",
            "title": "Better mood",
            "body": "Quality sleep is the foundation of feeling good."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "breath",
            "title": "Fresh breath",
            "body": "No more dry mouth or morning breath."
          }
        }
      ]
    }
  ]
}
{% endschema %}
