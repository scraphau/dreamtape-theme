<header class="header" style="{% render 'section-color-vars', section: section %}">
  <div class="header-inner">
    <button class="hamburger" aria-label="Open menu" data-menu-open>
      <span></span><span></span><span></span>
    </button>
    <a href="{{ routes.root_url }}" class="logo" aria-label="{{ shop.name }} home">
      <img
        src="{{ 'dreamtape-logo.png' | asset_url }}"
        alt="{{ shop.name }}"
        class="logo-image"
        width="1006"
        height="233"
      >
    </a>
    {%- assign nav_blocks = section.blocks | where: 'type', 'nav_link' -%}
    {%- assign use_custom_nav = false -%}
    {%- if nav_blocks.size > 0 -%}
      {%- assign use_custom_nav = true -%}
    {%- endif -%}
    {%- assign has_faq_link = false -%}
    {%- unless use_custom_nav -%}
      {%- for link in section.settings.menu.links -%}
        {%- assign link_title = link.title | downcase -%}
        {%- if link_title == 'faq' or link.url contains '/pages/faq' or link.url contains 'view=faq' -%}
          {%- assign has_faq_link = true -%}
        {%- endif -%}
      {%- endfor -%}
    {%- endunless -%}
    <nav class="nav-desktop">
      {%- if use_custom_nav -%}
        {%- for block in nav_blocks -%}
          {%- if block.settings.label != blank -%}
            <a href="{{ block.settings.link | default: routes.root_url }}" {{ block.shopify_attributes }}>{{ block.settings.label }}</a>
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        {%- for link in section.settings.menu.links -%}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {%- endfor -%}
        {%- unless has_faq_link -%}
          <a href="/search?view=faq">FAQ</a>
        {%- endunless -%}
      {%- endif -%}
    </nav>
    <div class="header-actions">
      {%- if section.settings.cta_text != blank -%}
        <a href="{{ section.settings.cta_link }}" class="btn-shop">{{ section.settings.cta_text }}</a>
      {%- endif -%}
      <a href="{{ routes.cart_url }}" class="cart-btn" aria-label="Cart">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        <span class="cart-count">{{ cart.item_count }}</span>
      </a>
    </div>
  </div>
</header>

<div class="mobile-menu-backdrop" id="mobileMenuBackdrop" data-menu-close></div>
<div class="mobile-menu" id="mobileMenu">
  <button class="close-btn" data-menu-close>&times;</button>
  {%- if use_custom_nav -%}
    {%- for block in nav_blocks -%}
      {%- if block.settings.label != blank -%}
        <a href="{{ block.settings.link | default: routes.root_url }}" data-menu-close {{ block.shopify_attributes }}>
          <span>{{ block.settings.label }}</span>
          <span aria-hidden="true">{% render 'nav-emoji', label: block.settings.label %}</span>
        </a>
      {%- endif -%}
    {%- endfor -%}
  {%- else -%}
    {%- for link in section.settings.menu.links -%}
      <a href="{{ link.url }}" data-menu-close>
        <span>{{ link.title }}</span>
        <span aria-hidden="true">{% render 'nav-emoji', label: link.title %}</span>
      </a>
    {%- endfor -%}
    {%- unless has_faq_link -%}
      <a href="/search?view=faq" data-menu-close>
        <span>FAQ</span>
        <span aria-hidden="true">❓</span>
      </a>
    {%- endunless -%}
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Header",
  "max_blocks": 8,
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#0e1a3a"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Muted text color",
      "default": "#5a6580"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#0e1a3a"
    },
    {
      "type": "color",
      "id": "card_background_color",
      "label": "Card background color",
      "default": "#ffffff"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Fallback main menu",
      "default": "main-menu"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA button text",
      "default": "Shop"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA button link"
    }
  ],
  "blocks": [
    {
      "type": "nav_link",
      "name": "Navigation link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Mouth Tape"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ]
}
{% endschema %}
