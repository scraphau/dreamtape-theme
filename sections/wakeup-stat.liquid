<section class="wakeup" style="{% render 'section-color-vars', section: section %}">
  <div class="container">
    <div class="wakeup-inner">
      <div class="wakeup-head">
        {%- if section.settings.eyebrow != blank -%}
          <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        <h2>{{ section.settings.heading }}</h2>
        <div class="wakeup-body">{{ section.settings.body }}</div>
      </div>
      <div class="wakeup-photo">
        <img
          src="{{ 'wakeup-photo.png' | asset_url }}"
          alt="Woman sleeping peacefully wearing Dreamtape mouth tape"
          width="1672"
          height="941"
          loading="lazy"
        >
      </div>
      {%- if section.settings.meta_text != blank or section.settings.button_text != blank -%}
        <div class="wakeup-footer">
          {%- if section.settings.meta_text != blank -%}
            <div class="wakeup-meta">{{ section.settings.meta_text }}</div>
          {%- endif -%}
          {%- if section.settings.button_text != blank -%}
            <a href="{{ section.settings.button_link }}" class="btn-primary btn-dark">
              {{ section.settings.button_text }} <span class="arrow">→</span>
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Wake-up stat",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#0e1a3a"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Muted text color",
      "default": "#5a6580"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#0e1a3a"
    },
    {
      "type": "color",
      "id": "card_background_color",
      "label": "Card background color",
      "default": "#0e1a3a"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The nasal breathing gap"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>6 in 10 adults sleep with their <em>mouth open</em>.</p>"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body text",
      "default": "<p>Open-mouth sleep dries out your airway, fragments deep sleep, and can soften your jawline over time.</p><p>Dreamtape trains your lips to stay gently closed, so you breathe the way you're built to — through your nose.</p>"
    },
    {
      "type": "header",
      "content": "Footer"
    },
    {
      "type": "text",
      "id": "meta_text",
      "label": "Meta text",
      "default": "From $0.59 per night"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Get Dreamtape"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Wake-up stat"
    }
  ]
}
{% endschema %}
