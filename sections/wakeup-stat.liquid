<section class="wakeup" style="{% render 'section-color-vars', section: section %}">
  <div class="container">
    <div class="wakeup-grid">
      <div class="wakeup-visual">
        <div class="stat-card">
          <div class="stat-number">{{ section.settings.stat_number }}<span class="percent">{{ section.settings.stat_unit }}</span></div>
          <div class="stat-label">{{ section.settings.stat_label }}</div>
        </div>
        <div class="stat-decor"></div>
      </div>
      <div class="wakeup-text">
        {%- if section.settings.eyebrow != blank -%}
          <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        <h2>{{ section.settings.heading }}</h2>
        <div>{{ section.settings.body }}</div>
        {%- if section.settings.button_text != blank -%}
          <a href="{{ section.settings.button_link }}" class="btn-primary btn-dark">
            {{ section.settings.button_text }} <span class="arrow">→</span>
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Wake-up stat",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#0e1a3a"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Muted text color",
      "default": "#5a6580"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#0e1a3a"
    },
    {
      "type": "color",
      "id": "card_background_color",
      "label": "Card background color",
      "default": "#0e1a3a"
    },
    {
      "type": "text",
      "id": "stat_number",
      "label": "Stat number",
      "default": "61"
    },
    {
      "type": "text",
      "id": "stat_unit",
      "label": "Stat unit",
      "default": "%"
    },
    {
      "type": "text",
      "id": "stat_label",
      "label": "Stat label",
      "default": "of adults are mouth breathers"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "A wake-up call"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Mouth breathing is wrecking your nights — and your <em>face</em>.</p>"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body text",
      "default": "<p>Snoring, dry mouth, disrupted REM, lower oxygenation, and a weaker facial structure. Most of us do it without realising.</p><p>Dreamtape gently guides your jaw closed so you nose-breathe through the night.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Try Dreamtape"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Wake-up stat"
    }
  ]
}
{% endschema %}
