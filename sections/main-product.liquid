<section id="product-form" class="product-page" style="{% render 'section-color-vars', section: section %}">
  <div class="container">
    <div class="product-layout">

      <!-- Gallery -->
      <div class="product-gallery">
        <div class="product-gallery-main" data-gallery-main>
          {%- if product.featured_media -%}
            <img src="{{ product.featured_media | image_url: width: 1200 }}" alt="{{ product.featured_media.alt | escape }}">
          {%- else -%}
            <div class="product-gallery-placeholder">
              <div class="pgp-inner">
                <span class="pgp-moon">◐</span>
                <p class="pgp-name">{{ product.title }}</p>
                <span class="pgp-note">Product image coming soon</span>
              </div>
            </div>
          {%- endif -%}

          {%- if section.settings.image_badge != blank -%}
            <div class="gallery-badge">{{ section.settings.image_badge }}</div>
          {%- endif -%}
        </div>

        {%- if product.media.size > 1 -%}
          <div class="product-thumbs">
            {%- for media in product.media -%}
              <div class="product-thumb {% if forloop.first %}active{% endif %}" data-gallery-thumb>
                <img src="{{ media | image_url: width: 200 }}" alt="">
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <!-- Info -->
      <div class="product-info">

        <!-- Rating -->
        <div class="product-rating-row">
          <span class="product-stars">★★★★★</span>
          <span class="product-rating-count">
            {%- if product.metafields.reviews.rating_count.value != blank -%}
              {{ product.metafields.reviews.rating.value }} ({{ product.metafields.reviews.rating_count.value }} reviews)
            {%- else -%}
              {{ section.settings.rating_text }}
            {%- endif -%}
          </span>
          {%- if section.settings.badge_text != blank -%}
            <span class="product-award-badge">{{ section.settings.badge_text }}</span>
          {%- endif -%}
        </div>

        <h1 class="product-title">{{ product.title }}</h1>

        {%- if section.settings.tagline != blank -%}
          <p class="product-tagline">{{ section.settings.tagline }}</p>
        {%- elsif product.metafields.custom.tagline.value != blank -%}
          <p class="product-tagline">{{ product.metafields.custom.tagline.value }}</p>
        {%- endif -%}

        {%- if section.settings.bullets != blank -%}
          <ul class="product-bullets">
            {%- assign bullets = section.settings.bullets | newline_to_br | split: '<br />' -%}
            {%- for bullet in bullets -%}
              {%- if bullet != blank -%}<li>{{ bullet }}</li>{%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}

        {%- form 'product', product -%}

          {%- if product.variants.size > 1 -%}

            <!-- Price row -->
            <div class="product-price-row">
              {%- assign first = product.selected_or_first_available_variant -%}
              <span class="product-price-current" data-current-price>{{ first.price | money_without_trailing_zeros }}</span>
              {%- if first.compare_at_price > first.price -%}
                <span class="product-price-compare" data-compare-price>{{ first.compare_at_price | money_without_trailing_zeros }}</span>
                {%- assign saved = first.compare_at_price | minus: first.price -%}
                <span class="product-price-save" data-save-badge>You save {{ saved | money_without_trailing_zeros }}</span>
              {%- endif -%}
            </div>

            <input type="hidden" name="id" value="{{ first.id }}" data-variant-input>

            <div class="variant-picker">
              <div class="variant-picker-divider"><span>Choose your pack</span></div>

              <div class="variant-options-stack" data-variant-picker>
                {%- for variant in product.variants -%}
                  {%- assign packs = 1 -%}
                  {%- assign months = 1 -%}
                  {%- if variant.title contains '3' or variant.title contains 'Three' -%}
                    {%- assign packs = 3 -%}
                    {%- assign months = 3 -%}
                  {%- elsif variant.title contains '6' or variant.title contains 'Six' -%}
                    {%- assign packs = 6 -%}
                    {%- assign months = 6 -%}
                  {%- endif -%}
                  {%- assign strips = packs | times: 30 -%}
                  {%- assign per_strip = variant.price | divided_by: strips -%}

                  {%- assign is_popular = false -%}
                  {%- assign is_deal = false -%}
                  {%- if variant.title contains '3' or variant.title contains 'Three' -%}
                    {%- assign is_popular = true -%}
                  {%- elsif variant.title contains '6' or variant.title contains 'Six' -%}
                    {%- assign is_deal = true -%}
                  {%- endif -%}

                  {%- assign discount_percent = 0 -%}
                  {%- if variant.compare_at_price > variant.price -%}
                    {%- assign saved_amount = variant.compare_at_price | minus: variant.price -%}
                    {%- assign discount_percent = saved_amount | times: 100 | divided_by: variant.compare_at_price -%}
                  {%- endif -%}

                  {%- assign selling_plan_id = '' -%}
                  {%- assign sub_price = '' -%}
                  {%- assign sub_compare = '' -%}
                  {%- assign sub_discount_percent = 0 -%}
                  {%- if variant.selling_plan_allocations.size > 0 -%}
                    {%- assign allocation = variant.selling_plan_allocations.first -%}
                    {%- assign selling_plan_id = allocation.selling_plan.id -%}
                    {%- assign sub_price = allocation.price | money_without_trailing_zeros -%}
                    {%- assign sub_compare = variant.price | money_without_trailing_zeros -%}
                    {%- if allocation.price < variant.price -%}
                      {%- assign sub_saved = variant.price | minus: allocation.price -%}
                      {%- assign sub_discount_percent = sub_saved | times: 100 | divided_by: variant.price -%}
                    {%- endif -%}
                  {%- endif -%}

                  <button type="button"
                    class="variant-card {% if forloop.first %}active{% endif %} {% if is_popular %}variant-card--popular{% elsif is_deal %}variant-card--deal{% endif %}"
                    data-variant-id="{{ variant.id }}"
                    data-price="{{ variant.price | money_without_trailing_zeros }}"
                    data-compare="{{ variant.compare_at_price | money_without_trailing_zeros }}"
                    data-discount="{{ discount_percent }}"
                    data-sub-price="{{ sub_price }}"
                    data-sub-compare="{{ sub_compare }}"
                    data-sub-discount="{{ sub_discount_percent }}"
                    data-per-strip="{{ per_strip | money }}"
                    data-selling-plan-id="{{ selling_plan_id }}">

                    {%- if is_popular -%}
                      <span class="vc-ribbon">Most Popular</span>
                    {%- elsif is_deal -%}
                      <span class="vc-ribbon">Best Deal</span>
                    {%- endif -%}

                    <div class="vc-select">
                      <span class="vc-radio"></span>
                    </div>

                    <div class="vc-body">
                      <div class="vc-top">
                        <span class="vc-title">{{ months }} Month Supply</span>
                        <span class="vc-pill" data-vc-pill {% if discount_percent == 0 %}style="display:none;"{% endif %}>{{ discount_percent }}% off</span>
                      </div>
                      <span class="vc-meta vc-meta--italic">{{ packs }} x 30 Pack{% if packs > 1 %}s{% endif %}</span>
                      <span class="vc-meta">FREE Shipping &amp; Container</span>
                    </div>

                    <div class="vc-pricing">
                      <span class="vc-price" data-vc-price>{{ variant.price | money_without_trailing_zeros }}</span>
                      <span class="vc-compare" data-vc-compare {% unless variant.compare_at_price > variant.price %}style="display:none;"{% endunless %}>{{ variant.compare_at_price | money_without_trailing_zeros }}</span>
                    </div>
                  </button>
                {%- endfor -%}
              </div>
            </div>

          {%- else -%}

            {%- assign single_variant = product.selected_or_first_available_variant -%}
            {%- assign selling_plan_id = '' -%}
            {%- assign sub_price = '' -%}
            {%- assign sub_compare = '' -%}
            {%- if single_variant.selling_plan_allocations.size > 0 -%}
              {%- assign allocation = single_variant.selling_plan_allocations.first -%}
              {%- assign selling_plan_id = allocation.selling_plan.id -%}
              {%- assign sub_price = allocation.price | money_without_trailing_zeros -%}
              {%- assign sub_compare = single_variant.price | money_without_trailing_zeros -%}
            {%- endif -%}
            <input type="hidden" name="id" value="{{ single_variant.id }}" data-single-variant-selling-plan="{{ selling_plan_id }}">
            <div class="product-price-row"
              data-price="{{ product.price | money_without_trailing_zeros }}"
              data-compare="{{ product.compare_at_price | money_without_trailing_zeros }}"
              data-sub-price="{{ sub_price }}"
              data-sub-compare="{{ sub_compare }}">
              <span class="product-price-current" data-current-price>{{ product.price | money_without_trailing_zeros }}</span>
              <span class="product-price-compare" data-compare-price {% unless product.compare_at_price > product.price %}style="display:none;"{% endunless %}>{{ product.compare_at_price | money_without_trailing_zeros }}</span>
              {%- assign saved = product.compare_at_price | minus: product.price -%}
              <span class="product-price-save" data-save-badge {% unless product.compare_at_price > product.price %}style="display:none;"{% endunless %}>You save {{ saved | money_without_trailing_zeros }}</span>
            </div>

          {%- endif -%}

          <!-- Subscribe & save toggle -->
          {%- if product.selling_plan_groups.size > 0 -%}
            <label class="product-subscribe-toggle">
              <input type="checkbox" data-subscribe-toggle>
              <span class="pst-check"></span>
              <span class="pst-body">
                <strong>Save more with Automatic Refills!</strong>
                <span>Zero commitment, Cancel Anytime</span>
              </span>
            </label>
            <input type="hidden" name="selling_plan" value="" data-selling-plan-input>
          {%- elsif section.settings.subscribe_note != blank -%}
            <div class="product-subscribe-note">
              <span class="psn-icon">🔄</span>
              <span>{{ section.settings.subscribe_note }}</span>
            </div>
          {%- endif -%}

          <button type="submit" class="btn-atc" {% unless product.available %}disabled{% endunless %}>
            {%- if product.available -%}
              Add to Cart — {{ section.settings.cta_suffix }}
            {%- else -%}
              Sold out
            {%- endif -%}
          </button>

          {%- if section.settings.sub_note != blank -%}
            <p class="product-sub-note">{{ section.settings.sub_note }}</p>
          {%- endif -%}

        {%- endform -%}

        <!-- Trust row -->
        <div class="product-trust-row">
          <div class="ptr-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <span>30-Night Guarantee</span>
          </div>
          <div class="ptr-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            <span>Free Shipping</span>
          </div>
          <div class="ptr-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Cancel Anytime</span>
          </div>
          <div class="ptr-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
            <span>Ships in 1–2 Days</span>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<script>
(function(){
  const form = document.getElementById('product-form');
  const subscribeToggle = form?.querySelector('[data-subscribe-toggle]');
  const sellingPlanInput = form?.querySelector('[data-selling-plan-input]');
  const curEl = form?.querySelector('[data-current-price]');
  const cmpEl = form?.querySelector('[data-compare-price]');
  const savEl = form?.querySelector('[data-save-badge]');
  let currentSellingPlanId = '';

  function isSubscribed() {
    return !!(subscribeToggle && subscribeToggle.checked);
  }

  function syncSellingPlanInput() {
    if (!sellingPlanInput) return;
    sellingPlanInput.value = isSubscribed() ? currentSellingPlanId : '';
  }

  // Update a card's own displayed price/discount pill for the current mode
  function applyCardPricing(card) {
    const subscribed = isSubscribed() && card.dataset.subPrice;
    const price    = subscribed ? card.dataset.subPrice   : card.dataset.price;
    const compare  = subscribed ? card.dataset.subCompare : card.dataset.compare;
    const discount = subscribed ? card.dataset.subDiscount : card.dataset.discount;

    const priceEl = card.querySelector('[data-vc-price]');
    const compareEl = card.querySelector('[data-vc-compare]');
    const pillEl = card.querySelector('[data-vc-pill]');

    if (priceEl) priceEl.textContent = price || '';
    if (compareEl) { compareEl.textContent = compare || ''; compareEl.style.display = compare ? '' : 'none'; }
    if (pillEl) {
      const pct = Number(discount || 0);
      pillEl.textContent = pct + '% off';
      pillEl.style.display = pct > 0 ? '' : 'none';
    }

    return { price, compare };
  }

  // Update the top price row from a given card (or the single-variant row)
  function applyTopPricing(source) {
    if (!source) return;
    const subscribed = isSubscribed() && source.dataset.subPrice;
    const price   = subscribed ? source.dataset.subPrice   : source.dataset.price;
    const compare = subscribed ? source.dataset.subCompare : source.dataset.compare;

    if (curEl) curEl.textContent = price || '';
    if (cmpEl) { cmpEl.textContent = compare || ''; cmpEl.style.display = compare ? '' : 'none'; }
    if (savEl) savEl.style.display = compare ? '' : 'none';
  }

  function refreshAllPricing() {
    document.querySelectorAll('.variant-card').forEach(applyCardPricing);
    const activeCard = document.querySelector('.variant-card.active');
    if (activeCard) {
      applyTopPricing(activeCard);
      currentSellingPlanId = activeCard.dataset.sellingPlanId || '';
    } else {
      const priceRow = form?.querySelector('.product-price-row[data-sub-price]');
      if (priceRow) applyTopPricing(priceRow);
    }
    syncSellingPlanInput();
  }

  if (subscribeToggle) {
    subscribeToggle.addEventListener('change', refreshAllPricing);
  }

  const singleVariantInput = form?.querySelector('[data-single-variant-selling-plan]');
  if (singleVariantInput) {
    currentSellingPlanId = singleVariantInput.dataset.singleVariantSellingPlan || '';
  }

  document.querySelectorAll('[data-variant-picker]').forEach(picker => {
    const frm   = picker.closest('form');
    const cards = picker.querySelectorAll('.variant-card');
    const input = frm?.querySelector('[data-variant-input]');

    cards.forEach(applyCardPricing);

    cards.forEach(card => {
      card.addEventListener('click', () => {
        cards.forEach(c => c.classList.remove('active'));
        card.classList.add('active');
        if (input) input.value = card.dataset.variantId;
        currentSellingPlanId = card.dataset.sellingPlanId || '';
        applyTopPricing(card);
        syncSellingPlanInput();
      });
    });
  });

  refreshAllPricing();
})();
</script>

{% schema %}
{
  "name": "Product info",
  "settings": [
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#0e1a3a" },
    { "type": "color", "id": "muted_text_color", "label": "Muted text color", "default": "#5a6580" },
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#0e1a3a" },
    { "type": "color", "id": "card_background_color", "label": "Card background color", "default": "#ffffff" },
    { "type": "header", "content": "Product content" },
    { "type": "text", "id": "rating_text", "label": "Rating text", "default": "4.9 · 2,847 reviews" },
    { "type": "text", "id": "badge_text", "label": "Award badge", "default": "#1 Mouth Tape" },
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "The last sleep upgrade you'll ever need." },
    { "type": "textarea", "id": "bullets", "label": "Feature bullets (one per line)", "default": "Reduced snoring & deeper sleep every night\nMore energy, sharper focus every morning\nStronger jaw & enhanced facial structure" },
    { "type": "text", "id": "image_badge", "label": "Image overlay badge", "default": "From $0.67/night" },
    { "type": "header", "content": "CTA & notes" },
    { "type": "text", "id": "cta_suffix", "label": "Button text suffix (after em dash)", "default": "Try Risk-Free" },
    { "type": "text", "id": "subscribe_note", "label": "Subscribe & save note", "default": "Save an extra 15% with Auto-Refills — pause or cancel anytime" },
    { "type": "text", "id": "sub_note", "label": "Below button note", "default": "30-night money-back guarantee · Free shipping" }
  ]
}
{% endschema %}
