<section class="final-cta" style="{% render 'section-color-vars', section: section %}">
  <div class="container">
    <div class="final-inner">
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow eyebrow-light">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 class="section-title" style="color: var(--cream);">{{ section.settings.heading }}</h2>
      {%- if section.settings.body != blank -%}
        <p>{{ section.settings.body }}</p>
      {%- endif -%}
      <a href="{{ section.settings.button_link }}" class="btn-primary btn-light btn-large">
        {{ section.settings.button_text }} <span class="arrow">→</span>
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Final CTA",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#0e1a3a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Muted text color",
      "default": "#dbe5f6"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_background_color",
      "label": "Card background color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Your next chapter"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Wake up to a<br><em>healthier you</em>.</p>"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "You spend a third of your life asleep. Make it count."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Try Dreamtape now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Final CTA"
    }
  ]
}
{% endschema %}
