<section class="testimonials">
  <div class="container">
    <div class="section-head section-head-center">
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 class="section-title">{{ section.settings.heading }}</h2>
    </div>
    <div class="testimonial-grid">
      {%- for block in section.blocks -%}
        <div class="testimonial">
          <div class="t-stars">★★★★★</div>
          <p>"{{ block.settings.quote }}"</p>
          <div class="t-author">
            <strong>{{ block.settings.author }}</strong>
            <span>{{ block.settings.author_meta }}</span>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "max_blocks": 9,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Real Dreamtape sleepers" },
    { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p>You'll want to <em>stock up</em>.</p>" }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Quote", "default": "Customer review goes here." },
        { "type": "text", "id": "author", "label": "Author name", "default": "Name S." },
        { "type": "text", "id": "author_meta", "label": "Author meta", "default": "Verified customer" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "testimonial", "settings": { "quote": "Dreamtape has been a lifesaver. I switched to a subscription because I never want to run out — my husband actually thanks me for it.", "author": "Laura P.", "author_meta": "Verified customer" } },
        { "type": "testimonial", "settings": { "quote": "I've tried every snoring fix on the market. Nothing comes close to this. My wife is happier, and I'm getting the best sleep I've had in years.", "author": "Mark S.", "author_meta": "Verified customer" } },
        { "type": "testimonial", "settings": { "quote": "I was sceptical, but I took the chance. No more dry mouth. No more grogginess. I genuinely wake up feeling like a different person.", "author": "Sabrina C.", "author_meta": "Verified customer" } }
      ]
    }
  ]
}
{% endschema %}
