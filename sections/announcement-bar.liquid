            <span>&#10022;</span>
            Free shipping over $79
            <span>&#10022;</span>
            30-night sleep trial
            <span>&#10022;</span>
            Subscribe &amp; save up to 50%
          </span>
        {%- endfor -%}
      </div>
    {%- endfor -%}
