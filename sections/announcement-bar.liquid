<a href="{{ section.settings.link | default: 'shopify://products/mouth-tape' }}" class="announcement" style="{% render 'section-color-vars', section: section %}" aria-label="Free AU shipping on subscriptions. Shop now.">
  <div class="announcement-track" aria-hidden="true">
    {%- for loop_index in (1..2) -%}
      <div class="announcement-sequence">
        <span class="announcement-message">&#10022;&nbsp;&nbsp;&nbsp;&nbsp;FREE AU SHIPPING ON SUBSCRIPTIONS&nbsp;&nbsp;&nbsp;&nbsp;&#10022;&nbsp;&nbsp;&nbsp;&nbsp;FREE AU SHIPPING ON SUBSCRIPTIONS&nbsp;&nbsp;&nbsp;&nbsp;&#10022;&nbsp;&nbsp;&nbsp;&nbsp;FREE AU SHIPPING ON SUBSCRIPTIONS&nbsp;&nbsp;&nbsp;&nbsp;&#10022;&nbsp;&nbsp;&nbsp;&nbsp;FREE AU SHIPPING ON SUBSCRIPTIONS</span>
      </div>
    {%- endfor -%}
  </div>
</a>

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#0e1a3a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Muted text color",
      "default": "#dbe5f6"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_background_color",
      "label": "Card background color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Link"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link",
      "info": "Where the bar goes when clicked. Defaults to the mouth tape product page."
    }
  ]
}
{% endschema %}
