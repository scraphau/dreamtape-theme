<section class="faq-page" style="{% render 'section-color-vars', section: section %}">
  <div class="container">
    <nav class="faq-breadcrumb" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">Home</a>
      <span>/</span>
      <span>{{ page.title | default: 'FAQ' }}</span>
    </nav>

    <div class="faq-page-hero">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        <h1>{{ section.settings.heading }}</h1>
      </div>
      <div class="faq-page-intro">
        {{ section.settings.intro }}
        {%- if section.settings.contact_text != blank -%}
          <p>
            {{ section.settings.contact_text }}
            {%- if section.settings.contact_link != blank -%}
              <a href="{{ section.settings.contact_link }}">{{ section.settings.contact_link_label }}</a>
            {%- endif -%}
          </p>
        {%- endif -%}
      </div>
    </div>

    <div class="faq-tabbed" data-faq-tabs>
      <div class="faq-tabs" role="tablist" aria-label="FAQ categories">
        <button class="faq-tab active" type="button" role="tab" aria-selected="true" aria-controls="faq-panel-mouth-tape" data-faq-tab="mouth-tape">Sleep Strips</button>
        <button class="faq-tab" type="button" role="tab" aria-selected="false" aria-controls="faq-panel-nose-strips" data-faq-tab="nose-strips">Nose Strips</button>
        <button class="faq-tab" type="button" role="tab" aria-selected="false" aria-controls="faq-panel-general" data-faq-tab="general">General</button>
      </div>

      <div class="faq-panels">
        <div class="faq-panel active" id="faq-panel-mouth-tape" role="tabpanel" data-faq-panel="mouth-tape">
          {%- for block in section.blocks -%}
            {%- if block.settings.category == 'mouth_tape' -%}
              <div class="faq-page-item" {{ block.shopify_attributes }}>
                <button type="button" class="faq-page-summary" aria-expanded="false">
                  <span class="faq-page-question">{{ block.settings.question }}</span>
                  <span class="faq-page-toggle" aria-hidden="true"></span>
                </button>
                <div class="faq-page-body">
                  <div class="faq-page-answer">{{ block.settings.answer }}</div>
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        <div class="faq-panel" id="faq-panel-nose-strips" role="tabpanel" data-faq-panel="nose-strips" hidden>
          {%- for block in section.blocks -%}
            {%- if block.settings.category == 'nose_strips' -%}
              <div class="faq-page-item" {{ block.shopify_attributes }}>
                <button type="button" class="faq-page-summary" aria-expanded="false">
                  <span class="faq-page-question">{{ block.settings.question }}</span>
                  <span class="faq-page-toggle" aria-hidden="true"></span>
                </button>
                <div class="faq-page-body">
                  <div class="faq-page-answer">{{ block.settings.answer }}</div>
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        <div class="faq-panel" id="faq-panel-general" role="tabpanel" data-faq-panel="general" hidden>
          {%- for block in section.blocks -%}
            {%- if block.settings.category == 'general' -%}
              <div class="faq-page-item" {{ block.shopify_attributes }}>
                <button type="button" class="faq-page-summary" aria-expanded="false">
                  <span class="faq-page-question">{{ block.settings.question }}</span>
                  <span class="faq-page-toggle" aria-hidden="true"></span>
                </button>
                <div class="faq-page-body">
                  <div class="faq-page-answer">{{ block.settings.answer }}</div>
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>

    <div class="faq-contact-panel">
      <div>
        <span class="eyebrow">Still wondering?</span>
        <h2>{{ section.settings.support_heading }}</h2>
        {{ section.settings.support_text }}
      </div>
      <a class="btn-primary" href="{{ section.settings.support_link }}">{{ section.settings.support_button }}</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ page",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#0e1a3a"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Muted text color",
      "default": "#5a6580"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#0e1a3a"
    },
    {
      "type": "color",
      "id": "card_background_color",
      "label": "Card background color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Help centre"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Dreamtape FAQs"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro",
      "default": "<p>We get it, optimizing your breath for better sleep can feel new. We made finding the answers simple, from how Dreamtape works to when and how often to use it.</p>"
    },
    {
      "type": "text",
      "id": "contact_text",
      "label": "Contact intro",
      "default": "For shipping, product troubleshooting, or anything more specific, visit our"
    },
    {
      "type": "url",
      "id": "contact_link",
      "label": "Contact link"
    },
    {
      "type": "text",
      "id": "contact_link_label",
      "label": "Contact link label",
      "default": "Contact page."
    },
    {
      "type": "text",
      "id": "support_heading",
      "label": "Support heading",
      "default": "Not finding what you are looking for?"
    },
    {
      "type": "richtext",
      "id": "support_text",
      "label": "Support text",
      "default": "<p>Send us a note and we will help you find the right answer before bedtime.</p>"
    },
    {
      "type": "text",
      "id": "support_button",
      "label": "Support button",
      "default": "Get help"
    },
    {
      "type": "url",
      "id": "support_link",
      "label": "Support button link"
    }
  ],
  "blocks": [
    {
      "type": "qa",
      "name": "Question",
      "settings": [
        {
          "type": "select",
          "id": "category",
          "label": "Category",
          "default": "mouth_tape",
          "options": [
            {
              "value": "mouth_tape",
              "label": "Mouth Tape"
            },
            {
              "value": "nose_strips",
              "label": "Nose Strips"
            },
            {
              "value": "general",
              "label": "General"
            }
          ]
        },
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Is Dreamtape safe to use?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Dreamtape is designed to be gentle, comfortable, and easy to remove. If you have breathing concerns, sleep apnea, blocked nasal passages, or a medical condition, check with a healthcare professional before use.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ page"
    }
  ]
}
{% endschema %}
