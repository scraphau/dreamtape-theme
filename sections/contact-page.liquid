<section class="contact-page" style="{% render 'section-color-vars', section: section %}">
  <div class="container">
    <nav class="contact-breadcrumb" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">Home</a>
      <span>/</span>
      <span>Contact</span>
    </nav>

    <div class="contact-layout">
      <div class="contact-hero">
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        <h1>{{ section.settings.heading }}</h1>
        <p class="contact-sub">{{ section.settings.subheading }}</p>
        <p class="contact-response-note">{{ section.settings.response_note }}</p>
      </div>

      <div class="contact-card">
        {%- form 'contact', id: 'ContactForm' -%}
          {%- if form.posted_successfully? -%}
            <div class="contact-success" role="status">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              {{ section.settings.success_message }}
            </div>
          {%- else -%}
            {%- if form.errors -%}
              <div class="contact-errors" role="alert">
                {{ form.errors | default_errors }}
              </div>
            {%- endif -%}

            <div class="contact-fields">
              <div class="contact-field">
                <label for="ContactForm-name">{{ section.settings.label_name }}</label>
                <input
                  type="text"
                  id="ContactForm-name"
                  name="contact[name]"
                  value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
                  autocomplete="name"
                  placeholder="{{ section.settings.placeholder_name }}"
                  required
                >
              </div>

              <div class="contact-field">
                <label for="ContactForm-email">{{ section.settings.label_email }}</label>
                <input
                  type="email"
                  id="ContactForm-email"
                  name="contact[email]"
                  value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
                  autocomplete="email"
                  autocorrect="off"
                  autocapitalize="off"
                  placeholder="{{ section.settings.placeholder_email }}"
                  required
                >
              </div>

              <div class="contact-field">
                <label for="ContactForm-order">
                  {{ section.settings.label_order }}
                  <span class="contact-optional">{{ section.settings.optional_label }}</span>
                </label>
                <input
                  type="text"
                  id="ContactForm-order"
                  name="contact[Order Number]"
                  placeholder="{{ section.settings.placeholder_order }}"
                >
              </div>

              <div class="contact-field contact-field--full">
                <label for="ContactForm-message">{{ section.settings.label_message }}</label>
                <textarea
                  id="ContactForm-message"
                  name="contact[body]"
                  rows="6"
                  placeholder="{{ section.settings.placeholder_message }}"
                  required
                >{{ form.body }}</textarea>
              </div>
            </div>

            <button type="submit" class="btn-primary btn-full">
              {{ section.settings.submit_label }} <span class="arrow">→</span>
            </button>
          {%- endif -%}
        {%- endform -%}
      </div>
    </div>

    {%- if section.settings.faq_heading != blank -%}
      <div class="contact-faq-cta">
        <div class="contact-faq-cta-inner">
          <div>
            <span class="eyebrow">{{ section.settings.faq_eyebrow }}</span>
            <h2>{{ section.settings.faq_heading }}</h2>
            <p>{{ section.settings.faq_subtext }}</p>
          </div>
          <a href="{{ section.settings.faq_link }}" class="btn-primary">
            {{ section.settings.faq_button }} <span class="arrow">→</span>
          </a>
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .contact-page {
    background: var(--section-bg, var(--paper));
    color: var(--section-text, var(--ink));
    padding: 60px 0 100px;
    min-height: 70vh;
  }

  .contact-breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--section-muted, var(--muted));
    margin-bottom: 56px;
  }
  .contact-breadcrumb a { transition: color 0.2s; }
  .contact-breadcrumb a:hover { color: var(--section-text, var(--ink)); }
  .contact-breadcrumb span { opacity: 0.6; }
  .contact-breadcrumb span:last-child { opacity: 1; }

  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }

  .contact-hero { padding-top: 8px; }
  .contact-hero h1 {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(36px, 4.5vw, 58px);
    line-height: 1.06;
    letter-spacing: -0.03em;
    margin-bottom: 20px;
    color: var(--section-text, var(--ink));
  }
  .contact-sub {
    font-size: 17px;
    line-height: 1.55;
    color: var(--section-muted, var(--muted));
    margin-bottom: 16px;
  }
  .contact-response-note {
    font-size: 14px;
    color: var(--section-muted, var(--muted));
    opacity: 0.7;
  }

  .contact-card {
    background: var(--section-card-bg, var(--cream-warm));
    border: 1px solid var(--line);
    border-radius: 20px;
    padding: 48px;
    box-shadow: var(--shadow-soft);
  }

  .contact-fields {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 24px;
  }
  .contact-field { display: flex; flex-direction: column; gap: 8px; }
  .contact-field--full { grid-column: 1 / -1; }

  .contact-field label {
    font-size: 13.5px;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--section-text, var(--ink));
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .contact-optional {
    font-weight: 400;
    font-size: 12px;
    color: var(--section-muted, var(--muted));
    opacity: 0.7;
  }

  .contact-field input,
  .contact-field textarea {
    width: 100%;
    padding: 14px 18px;
    border: 1px solid var(--line);
    border-radius: 10px;
    background: var(--section-bg, var(--paper));
    color: var(--section-text, var(--ink));
    font-family: var(--font-sans);
    font-size: 15px;
    line-height: 1.5;
    transition: border-color 0.2s, box-shadow 0.2s;
    appearance: none;
    -webkit-appearance: none;
  }
  .contact-field input::placeholder,
  .contact-field textarea::placeholder {
    color: var(--section-muted, var(--muted));
    opacity: 0.5;
  }
  .contact-field input:focus,
  .contact-field textarea:focus {
    outline: none;
    border-color: var(--section-accent, var(--midnight));
    box-shadow: 0 0 0 3px rgba(14, 26, 58, 0.08);
  }
  .contact-field textarea { resize: vertical; min-height: 140px; }

  .contact-success {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 20px 24px;
    background: #e8f5e9;
    border: 1px solid #a5d6a7;
    border-radius: 10px;
    color: #2e7d32;
    font-size: 15px;
    font-weight: 500;
  }

  .contact-errors {
    padding: 16px 20px;
    background: #fdecea;
    border: 1px solid #f5c6cb;
    border-radius: 10px;
    color: #c62828;
    font-size: 14px;
    margin-bottom: 20px;
  }

  .contact-faq-cta {
    margin-top: 80px;
    border-top: 1px solid var(--line);
    padding-top: 60px;
  }
  .contact-faq-cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
    flex-wrap: wrap;
  }
  .contact-faq-cta-inner h2 {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(28px, 3.5vw, 42px);
    letter-spacing: -0.025em;
    line-height: 1.1;
    margin-bottom: 10px;
    color: var(--section-text, var(--ink));
  }
  .contact-faq-cta-inner p {
    font-size: 16px;
    color: var(--section-muted, var(--muted));
  }

  @media (max-width: 900px) {
    .contact-layout { grid-template-columns: 1fr; gap: 48px; }
    .contact-card { padding: 32px 24px; }
    .contact-fields { grid-template-columns: 1fr; }
    .contact-faq-cta-inner { flex-direction: column; align-items: flex-start; }
  }
</style>

