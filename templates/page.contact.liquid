{% comment %}
  Respire-style contact page
  Drop in as templates/page.contact.liquid (or rename the suffix you assign in the theme editor).
  Self-contained: scoped styles + Shopify {% form 'contact' %}. Tweak colors/copy freely.
{% endcomment %}

<div class="rp-contact">

  {%- comment -%} ===== FORM SECTION ===== {%- endcomment -%}
  <section class="rp-form-section">
    <div class="rp-container rp-form-grid">

      <div class="rp-form-intro">
        <h1 class="rp-title">Questions or Feedback?</h1>
        <p class="rp-lead">
          Just breathe easy and fill out the form below. The {{ shop.name }} team
          will get back to you within 24 hours.
        </p>
        <p class="rp-sub">
          For media and partnership enquiries, email us directly at
          <a href="mailto:{{ shop.email }}">{{ shop.email }}</a>
        </p>
      </div>

      <div class="rp-form-wrap">
        {% form 'contact' %}
          {% if form.posted_successfully? %}
            <p class="rp-success">Thanks — your message is on its way. We'll be in touch within 24 hours.</p>
          {% endif %}
          {% if form.errors %}
            <div class="rp-errors">
              {% for field in form.errors %}
                <p>{{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}</p>
              {% endfor %}
            </div>
          {% endif %}

          <div class="rp-row">
            <div class="rp-field">
              <label for="rp-name">Name</label>
              <input type="text" id="rp-name" name="contact[name]"
                value="{% if form.name %}{{ form.name }}{% endif %}" required>
            </div>
            <div class="rp-field">
              <label for="rp-email">Email</label>
              <input type="email" id="rp-email" name="contact[email]"
                value="{% if form.email %}{{ form.email }}{% endif %}" required>
            </div>
          </div>

          <div class="rp-row">
            <div class="rp-field">
              <label for="rp-country">Country</label>
              <select id="rp-country" name="contact[country]">
                <option value="" disabled selected>Select your country</option>
                <option value="Australia">Australia</option>
                <option value="United Kingdom">United Kingdom</option>
                <option value="United States">United States</option>
                <option value="Other">Other</option>
              </select>
            </div>
            <div class="rp-field">
              <label for="rp-order">Order Number <span class="rp-optional">(optional)</span></label>
              <input type="text" id="rp-order" name="contact[order_number]">
            </div>
          </div>

          <div class="rp-field rp-field-full">
            <label for="rp-message">Your Message</label>
            <textarea id="rp-message" name="contact[body]" rows="6" required>{% if form.body %}{{ form.body }}{% endif %}</textarea>
          </div>

          <button type="submit" class="rp-btn">SEND IT</button>
        {% endform %}
      </div>

    </div>
  </section>

  {%- comment -%} ===== ASAP / FAQ CALLOUT ===== {%- endcomment -%}
  <section class="rp-asap-section">
    <div class="rp-container rp-asap">
      <div class="rp-asap-text">
        <h2>Need answers ASAP?</h2>
        <p>Not finding what you're looking for?</p>
      </div>
      <a class="rp-asap-btn" href="{{ pages.faq.url | default: '/pages/faq' }}">
        VISIT OUR FAQ PAGE
        <span class="rp-arrow" aria-hidden="true">&rarr;</span>
      </a>
    </div>
  </section>

  {%- comment -%} ===== TRUST BADGES ===== {%- endcomment -%}
  <section class="rp-badges-section">
    <div class="rp-container rp-badges">
      <div class="rp-badge"><span class="rp-badge-ico">☁</span><span>100% Safe &amp; Comfortable</span></div>
      <div class="rp-badge"><span class="rp-badge-ico">📈</span><span>Science Backed Benefits</span></div>
      <div class="rp-badge"><span class="rp-badge-ico">✓</span><span>30-Day Money Back Guarantee</span></div>
      <div class="rp-badge"><span class="rp-badge-ico">✈</span><span>FREE Shipping With Subscriptions</span></div>
    </div>
  </section>

</div>

<style>
  .rp-contact {
    --rp-ink: #12233b;
    --rp-blue: #2f6df0;
    --rp-blue-dark: #1f55c9;
    --rp-soft: #f3f7ff;
    --rp-line: #d9e2f1;
    --rp-muted: #5a6b82;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    color: var(--rp-ink);
  }
  .rp-container { max-width: 1080px; margin: 0 auto; padding: 0 24px; }

  /* Form section */
  .rp-form-section { padding: 72px 0 56px; }
  .rp-form-grid {
    display: grid; grid-template-columns: 0.85fr 1.15fr; gap: 56px; align-items: start;
  }
  .rp-title { font-size: 2.4rem; line-height: 1.1; font-weight: 800; margin: 0 0 18px; letter-spacing: -0.02em; }
  .rp-lead { font-size: 1.05rem; line-height: 1.55; margin: 0 0 16px; }
  .rp-sub { font-size: .95rem; color: var(--rp-muted); line-height: 1.55; margin: 0; }
  .rp-sub a, .rp-form-intro a { color: var(--rp-blue); text-decoration: none; font-weight: 600; }
  .rp-sub a:hover { text-decoration: underline; }

  .rp-form-wrap {
    background: var(--rp-soft);
    border: 1px solid var(--rp-line);
    border-radius: 18px;
    padding: 32px;
  }
  .rp-row { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
  .rp-field { margin-bottom: 18px; display: flex; flex-direction: column; }
  .rp-field-full { margin-bottom: 22px; }
  .rp-field label { font-size: .82rem; font-weight: 700; margin-bottom: 7px; letter-spacing: .01em; }
  .rp-optional { font-weight: 400; color: var(--rp-muted); }
  .rp-field input,
  .rp-field select,
  .rp-field textarea {
    width: 100%; box-sizing: border-box;
    border: 1px solid var(--rp-line);
    border-radius: 11px;
    padding: 13px 14px;
    font-size: 1rem;
    background: #fff;
    color: var(--rp-ink);
    transition: border-color .15s, box-shadow .15s;
    font-family: inherit;
  }
  .rp-field textarea { resize: vertical; }
  .rp-field input:focus,
  .rp-field select:focus,
  .rp-field textarea:focus {
    outline: none;
    border-color: var(--rp-blue);
    box-shadow: 0 0 0 3px rgba(47,109,240,.15);
  }

  .rp-btn {
    width: 100%;
    background: var(--rp-blue);
    color: #fff; border: none;
    border-radius: 12px;
    padding: 16px;
    font-size: 1rem; font-weight: 800; letter-spacing: .06em;
    cursor: pointer;
    transition: background .15s, transform .05s;
  }
  .rp-btn:hover { background: var(--rp-blue-dark); }
  .rp-btn:active { transform: translateY(1px); }

  .rp-success {
    background: #e6f7ec; border: 1px solid #b7e4c7; color: #1c7a43;
    border-radius: 10px; padding: 12px 14px; margin-bottom: 18px; font-weight: 600;
  }
  .rp-errors {
    background: #fdecec; border: 1px solid #f5c2c2; color: #b3261e;
    border-radius: 10px; padding: 12px 14px; margin-bottom: 18px;
  }
  .rp-errors p { margin: 4px 0; }

  /* ASAP callout */
  .rp-asap-section { padding: 8px 0 56px; }
  .rp-asap {
    background: var(--rp-ink);
    color: #fff;
    border-radius: 18px;
    padding: 38px 44px;
    display: flex; align-items: center; justify-content: space-between; gap: 24px; flex-wrap: wrap;
  }
  .rp-asap h2 { margin: 0 0 6px; font-size: 1.6rem; font-weight: 800; }
  .rp-asap p { margin: 0; color: #b9c6da; }
  .rp-asap-btn {
    display: inline-flex; align-items: center; gap: 10px;
    background: var(--rp-blue);
    color: #fff; text-decoration: none;
    padding: 15px 26px; border-radius: 12px;
    font-weight: 800; letter-spacing: .05em; font-size: .9rem;
    transition: background .15s;
  }
  .rp-asap-btn:hover { background: var(--rp-blue-dark); }
  .rp-arrow { transition: transform .15s; }
  .rp-asap-btn:hover .rp-arrow { transform: translateX(4px); }

  /* Badges */
  .rp-badges-section { padding: 0 0 72px; }
  .rp-badges {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px;
    border-top: 1px solid var(--rp-line); padding-top: 36px;
  }
  .rp-badge {
    display: flex; flex-direction: column; align-items: center; text-align: center; gap: 10px;
    font-size: .9rem; font-weight: 600; color: var(--rp-ink);
  }
  .rp-badge-ico {
    width: 46px; height: 46px; border-radius: 50%;
    background: var(--rp-soft); border: 1px solid var(--rp-line);
    display: flex; align-items: center; justify-content: center; font-size: 1.2rem;
  }

  /* Responsive */
  @media (max-width: 860px) {
    .rp-form-grid { grid-template-columns: 1fr; gap: 32px; }
    .rp-badges { grid-template-columns: repeat(2, 1fr); gap: 28px 20px; }
    .rp-asap { padding: 30px 28px; }
    .rp-title { font-size: 2rem; }
  }
  @media (max-width: 520px) {
    .rp-row { grid-template-columns: 1fr; gap: 0; }
    .rp-form-wrap { padding: 22px; }
    .rp-badges { grid-template-columns: 1fr 1fr; }
  }
</style>
