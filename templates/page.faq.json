        "mouth-what": {
          "type": "qa",
          "settings": {
            "category": "mouth_tape",
            "question": "What are Dreamtape Sleep Strips?",
            "answer": "<p>Dreamtape Sleep Strips are a soft, hypoallergenic strip that rests gently across your lips, training your body toward nasal breathing while you sleep. Breathing through your nose overnight filters and humidifies the air, cuts down on snoring, and helps you reach deeper, more restorative sleep, while mouth breathing dries out your airway and leaves you waking up groggy. It takes five seconds to apply, and most people notice the difference by morning.</p>"
          }
        },
        "mouth-use": {
          "type": "qa",
          "settings": {
            "category": "mouth_tape",
            "question": "How do I use Dreamtape?",
            "answer": "<p>Start with clean, dry lips — skip heavy balm or moisturizer beforehand. Peel one strip from the sheet, center it across your closed lips with the breathing slit uncovered, and press the edges down so it feels secure. In the morning, peel it off slowly from one corner for the most comfortable removal.</p>"
          }
        },
        "mouth-safe": {
          "type": "qa",
          "settings": {
            "category": "mouth_tape",
            "question": "Is mouth taping safe?",
            "answer": "<p>Dreamtape is made for healthy adults with clear nasal breathing. If you have sleep apnea, breathing concerns, blocked nasal passages, or a medical condition, speak with a healthcare professional before use.</p>"
          }
        },
        "mouth-remove": {
          "type": "qa",
          "settings": {
            "category": "mouth_tape",
            "question": "Will it hurt to remove?",
            "answer": "<p>No. Dreamtape is designed for gentle, comfortable removal. Peel slowly from one side and remove it with care.</p>"
          }
        },
        "mouth-beard": {
          "type": "qa",
          "settings": {
            "category": "mouth_tape",
            "question": "Can I use it with facial hair?",
            "answer": "<p>Yes, many customers use Dreamtape with light facial hair. For the best hold, apply it to clean, dry skin and avoid heavy oils or balms before bed.</p>"
          }
        },
        "mouth-reuse": {
          "type": "qa",
          "settings": {
            "category": "mouth_tape",
            "question": "Are the strips reusable?",
            "answer": "<p>No. For hygiene and adhesive performance, each Dreamtape strip is single-use.</p>"
          }
        },
        "mouth-count": {
          "type": "qa",
          "settings": {
            "category": "mouth_tape",
            "question": "How many strips come in each pack?",
            "answer": "<p>Each pack gives you a 30-night supply, one gentle strip for every night of the month. Larger packs simply bundle multiple 30-strip packs together so you always have a fresh supply on hand.</p>"
          }
        },
        "mouth-cold": {
          "type": "qa",
          "settings": {
            "category": "mouth_tape",
            "question": "Can I use it if I have a stuffy nose or cold?",
            "answer": "<p>We recommend skipping mouth taping on nights when your nose is congested, since the breathing slit still relies on clear nasal airflow. Wait until congestion clears, or check with a healthcare professional if it lingers.</p>"
          }
        },
        "mouth-material": {
          "type": "qa",
          "settings": {
            "category": "mouth_tape",
            "question": "What is Dreamtape made from?",
            "answer": "<p>Dreamtape strips use a soft, hypoallergenic, latex-free adhesive designed for sensitive skin, so it holds gently in place all night without irritation.</p>"
          }
        },
